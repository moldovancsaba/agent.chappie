AGENT_MODEL=llama3:latest
OLLAMA_URL=http://127.0.0.1:11434/api/generate
# Route model calls through agent.meimei (see docs/meimei-integration.md):
# OLLAMA_URL=http://127.0.0.1:3030/api/llm/gateway/generate
# MEIMEI_LLM_GATEWAY_SECRET=replace-me
FETCH_CHAR_LIMIT=4000
DRAFTER_MODEL=llama3:latest
WRITER_MODEL=llama3:latest
JUDGE_MODEL=llama3:latest

# Phase 4 app-layer placeholders
NEXT_PUBLIC_APP_NAME=Agent.Chappie Demo
NEXT_PUBLIC_APP_URL=http://localhost:3000
APP_ID=app_consultant_followup
# queue = hosted app uses Neon job queue only (Mac pulls); omit AGENT_API_BASE_URL on Vercel.
AGENT_BRIDGE_MODE=worker
AGENT_API_BASE_URL=http://127.0.0.1:8787
AGENT_SHARED_SECRET=replace-me
WORKER_QUEUE_SHARED_SECRET=replace-me
APP_QUEUE_BASE_URL=http://localhost:3000
AGENT_LOCAL_DB_PATH=runtime_status/agent_brain.sqlite3
DEMO_STORAGE_MODE=memory
# DATABASE_URL is for app/shared state only when using Neon-backed job/result storage.
DATABASE_URL=postgres://user:password@host/database?sslmode=require
