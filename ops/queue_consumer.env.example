# Copy to repo root as `.env.queue` (gitignored) or merge into `.env.local`.
# Required for worker_queue_consumer.py (Neon handoff).

APP_QUEUE_BASE_URL=https://your-app.vercel.app
WORKER_QUEUE_SHARED_SECRET=your-shared-secret

# Optional
# WORKER_QUEUE_POLL_SECONDS=3
# AGENT_LOCAL_DB_PATH=runtime_status/agent_brain.sqlite3
# AGENT_AUTO_RESEARCH_ENABLED=0
#
# Reliability (defaults are safe for large job_result JSON + Neon)
# WORKER_HTTP_TIMEOUT_CLAIM=60
# WORKER_HTTP_TIMEOUT_COMPLETE=600
# WORKER_COMPLETE_ATTEMPTS=12
# WORKER_HTTP_TIMEOUT_WORKSPACE=300
# WORKER_WORKSPACE_ATTEMPTS=8
# WORKER_RETRY_SLEEP_CAP_SECONDS=90
# Process one job then exit 0 (testing / cron)
# WORKER_QUEUE_DRAIN_ONCE=1
